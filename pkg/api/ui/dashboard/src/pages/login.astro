---
import "../styles/globals.css";
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>glory-hole — Login</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="h-screen flex items-center justify-center bg-background text-foreground antialiased">
    <div class="w-full max-w-sm space-y-8 px-4">
      <!-- Logo -->
      <div class="text-center space-y-2">
        <div class="flex justify-center">
           <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gh-purple/10">
            <svg
              class="h-8 w-8 text-gh-purple"
              viewBox="0 0 32 32"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="16" cy="16" r="12" />
              <circle cx="16" cy="14" r="4" />
              <rect x="14.5" y="17" width="3" height="5" rx="1.5" fill="currentColor" />
            </svg>
          </div>
        </div>
        <h1 class="text-xl font-bold glow-purple text-gh-purple font-data">GLORY-HOLE</h1>
        <p class="text-sm text-muted-foreground">Sign in to access the dashboard</p>
      </div>

      <!-- Login form -->
      <div class="rounded-xl border border-border bg-card p-6 space-y-6">
        <!-- Tab selector -->
        <div class="flex rounded-lg bg-muted p-1" id="auth-tabs">
          <button
            type="button"
            class="auth-tab flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-all bg-background text-foreground shadow"
            data-tab="apikey"
          >
            API Key
          </button>
          <button
            type="button"
            class="auth-tab flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-all text-muted-foreground hover:text-foreground"
            data-tab="password"
          >
            Password
          </button>
        </div>

        <!-- Error message -->
        <div id="login-error" class="hidden rounded-lg border border-gh-red/30 bg-gh-red/10 px-4 py-3 text-sm text-gh-red"></div>

        <!-- API Key form -->
        <form id="form-apikey" method="POST" action="/login" class="space-y-4">
          <input type="hidden" name="next" id="next-apikey" value="/" />
          <div class="space-y-2">
            <label class="text-xs font-medium uppercase tracking-wider text-muted-foreground" for="api_key">
              API Key
            </label>
            <input
              type="password"
              id="api_key"
              name="api_key"
              placeholder="Enter your API key"
              required
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm font-data shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
            />
          </div>
          <button
            type="submit"
            class="inline-flex h-9 w-full items-center justify-center rounded-md bg-primary text-primary-foreground text-sm font-medium shadow-md hover:bg-primary/90 transition-all active:scale-[0.97]"
          >
            Sign In
          </button>
        </form>

        <!-- Password form -->
        <form id="form-password" method="POST" action="/login" class="hidden space-y-4">
          <input type="hidden" name="next" id="next-password" value="/" />
          <div class="space-y-2">
            <label class="text-xs font-medium uppercase tracking-wider text-muted-foreground" for="username">
              Username
            </label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="admin"
              required
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
            />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-medium uppercase tracking-wider text-muted-foreground" for="password">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your password"
              required
              class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
            />
          </div>
          <button
            type="submit"
            class="inline-flex h-9 w-full items-center justify-center rounded-md bg-primary text-primary-foreground text-sm font-medium shadow-md hover:bg-primary/90 transition-all active:scale-[0.97]"
          >
            Sign In
          </button>
        </form>
      </div>
    </div>

    <script>
      // Parse ?next= parameter
      const params = new URLSearchParams(window.location.search);
      const next = params.get("next") || "/";
      document.querySelectorAll<HTMLInputElement>("[id^=next-]").forEach((el) => { el.value = next; });

      // Parse ?error= parameter
      const error = params.get("error");
      if (error) {
        const errEl = document.getElementById("login-error");
        if (errEl) {
          errEl.textContent = error;
          errEl.classList.remove("hidden");
        }
      }

      // Tab switching
      const tabs = document.querySelectorAll<HTMLButtonElement>(".auth-tab");
      const formApiKey = document.getElementById("form-apikey");
      const formPassword = document.getElementById("form-password");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            if (t.dataset.tab === target) {
              t.classList.add("bg-background", "text-foreground", "shadow");
              t.classList.remove("text-muted-foreground");
            } else {
              t.classList.remove("bg-background", "text-foreground", "shadow");
              t.classList.add("text-muted-foreground");
            }
          });
          if (target === "apikey") {
            formApiKey?.classList.remove("hidden");
            formPassword?.classList.add("hidden");
          } else {
            formApiKey?.classList.add("hidden");
            formPassword?.classList.remove("hidden");
          }
        });
      });
    </script>
  </body>
</html>
